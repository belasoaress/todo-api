{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": "warn",
    "semi": ["error", "always"],
    "quotes": ["error", "double"],
    "eqeqeq": "error",
    "no-console": "off"
  }
}
